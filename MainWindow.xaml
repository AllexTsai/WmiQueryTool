<Window x:Class="WmiQueryTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WMI Query Tool" Height="350" Width="500">
    <Grid Margin="10">
        <StackPanel>
            <TextBox x:Name="QueryBox" Height="30" 
                     Text="SELECT * FROM Win32_OperatingSystem"/>
            <Button Content="Run Query" Height="30" Margin="0,10,0,10"
                    Click="RunQuery_Click"/>
            <ListBox x:Name="ResultBox" Height="200"/>
        </StackPanel>
    </Grid>
</Window>
