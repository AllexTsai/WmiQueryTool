<Window x:Class="WmiQueryTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WMI Query Tool" Height="600" Width="900">
    <Grid Margin="10">
        <TabControl>
            <!-- 查詢設定分頁 -->
            <TabItem Header="Query Settings">
                <StackPanel Margin="10">
                    <!-- 常用查詢 -->
                    <GroupBox Header="Common Queries" Margin="0,0,0,10">
                        <ComboBox x:Name="QuerySelector" Height="30" SelectionChanged="QuerySelector_Changed">
                            <ComboBoxItem Content="Operating System" Tag="Win32_OperatingSystem"/>
                            <ComboBoxItem Content="Processor" Tag="Win32_Processor"/>
                            <ComboBoxItem Content="Video Controller" Tag="Win32_VideoController"/>
                            <ComboBoxItem Content="Physical Memory" Tag="Win32_PhysicalMemory"/>
                        </ComboBox>
                    </GroupBox>

                    <!-- 自訂查詢 -->
                    <GroupBox Header="Custom Query" Margin="0,0,0,10">
                        <TextBox x:Name="QueryBox" Height="60" AcceptsReturn="True" 
                                 Text="SELECT * FROM Win32_OperatingSystem"/>
                    </GroupBox>

                    <!-- 查詢歷史 -->
                    <GroupBox Header="Query History" Margin="0,10,0,10">
                        <ListBox x:Name="HistoryList" Height="100" SelectionChanged="HistoryList_SelectionChanged"/>
                    </GroupBox>

                    <!-- 查詢範本 (可收合) -->
                    <Expander Header="Query Templates" IsExpanded="False" Margin="0,10,0,10">
                        <ComboBox x:Name="TemplateSelector" Height="30" SelectionChanged="TemplateSelector_Changed">
                            <ComboBoxItem Content="Operating System Info" Tag="SELECT Caption, Version, BuildNumber FROM Win32_OperatingSystem"/>
                            <ComboBoxItem Content="CPU Info" Tag="SELECT Name, NumberOfCores, NumberOfLogicalProcessors FROM Win32_Processor"/>
                            <ComboBoxItem Content="GPU Info" Tag="SELECT Name, DriverVersion, AdapterRAM FROM Win32_VideoController"/>
                            <ComboBoxItem Content="Memory Info" Tag="SELECT Manufacturer, Capacity, Speed FROM Win32_PhysicalMemory"/>
                            <ComboBoxItem Content="Disk Info" Tag="SELECT Model, Size, InterfaceType FROM Win32_DiskDrive"/>
                        </ComboBox>
                    </Expander>

                    <!-- 操作按鈕 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                        <Button Content="Run Query" Width="100" Margin="0,0,10,0"
                                ToolTip="執行目前的 WMI 查詢"
                                Click="RunQuery_Click"/>
                        <Button Content="Export to CSV" Width="120"
                                ToolTip="將查詢結果匯出成 CSV 檔"
                                Click="ExportCsv_Click"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- 查詢結果分頁 -->
            <TabItem Header="Results">
                <DockPanel Margin="10">
                    <DataGrid x:Name="ResultGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" DockPanel.Dock="Top" Height="450"
                              CanUserSortColumns="True" CanUserReorderColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ObjectId" Binding="{Binding ObjectId}" Width="120"/>
                            <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- 狀態列 -->
                    <StatusBar DockPanel.Dock="Bottom">
                        <StatusBarItem>
                            <TextBlock x:Name="StatusMessage" Text="Ready" />
                        </StatusBarItem>
                    </StatusBar>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>